<html>
    <head>
        <title>New Message</title>
    </head>
    <body>
        <%- include('partials/errors.ejs') %>
        <form action="/new" method="POST">
            <h1>New Message:</h1>
            <label for="messageName">Name: </label>
            <input type="text" name="messageName" id="messageName" required>
            <label for="messageText">Text (100 characters max): </label>
             <textarea name="messageText" id="messageText" rows="5" cols="30" maxlength="100" required></textarea>
            <button type="submit">Submit</button>
        </form>
        <a href="/">
            <button>Back to Homepage</button>
        </a>
    </body>
</html>