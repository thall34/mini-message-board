<html>
    <head>
        <title>New Message</title>
    </head>
    <body>
        <form method="POST" action="/new">
            <h1>New Message:</h1>
            <label for="name">Name: </label>
            <input type="text" name="messageName" id="name">
            <label for="text">Text (100 characters max): </label>
             <textarea name="messageText" id="text" rows="5" cols="30" maxlength="100"></textarea>
            <button type="submit">Submit</button>
        </form>
        <a href="/">
            <button>Back to Homepage</button>
        </a>
    </body>
</html>